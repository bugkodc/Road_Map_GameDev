{
  "title": "Unreal Engine 5.7 Documentation",
  "html": "<main><header class=\"section-page-header\"><div class=\"row d-flex justify-content-between\"><div class=\"col col-sm-10\"></div><!----></div><!----><h1>Unreal Engine 5.7 Documentation</h1><p class=\"text-secondary mb-0\"> Complete resources for learning to use Unreal Engine 5 </p><!----></header><!----><div class=\"row\"><div class=\"col-lg-9 print-w-100\"><div class=\"b-img\"><img class=\"unreal-doc-img\" class=\"img-fluid\" alt=\"Unreal Engine 5.7 Documentation\" width=\"1920\" height=\"335\" loading=\"lazy\" fetchpriority=\"auto\" decoding=\"auto\" ng-img=\"true\" src=\"https://dev.epicgames.com/community/api/documentation/image/9f730f10-82c0-43f7-8e33-2224a51e063c?resizing_type=fill&amp;width=1920&amp;height=335\" srcset=\"https://dev.epicgames.com/community/api/documentation/image/9f730f10-82c0-43f7-8e33-2224a51e063c?resizing_type=fill&amp;width=1920&amp;height=335 1x, https://dev.epicgames.com/community/api/documentation/image/9f730f10-82c0-43f7-8e33-2224a51e063c?resizing_type=fill&amp;width=3840&amp;height=670 2x\"></div><!----><!----><!----><header class=\"document-header mb-3 d-lg-none d-print-none\"><content-nav class=\"content-nav is-collapsible\" ngh=\"6\"><!----><!----></content-nav></header><!----><article><!----><!----><div document-content-blocks-renderer=\"\" class=\"d-block\" ngh=\"12\"><div id=\"content-blocks-renderer\" class=\"content-blocks-renderer\"><block-switch-control class=\"block-switch-control\" ngh=\"7\"><!----></block-switch-control><block-switch-info class=\"block-switch-info\" ngh=\"8\"><!----></block-switch-info><blocks-renderer id=\"blocks-renderer\" ngh=\"11\"><!----><!----><!----><!----><!----><!----><!----><!----><!----><ul block-document-list=\"\" class=\"block-document-list\" ngh=\"10\"><li block-dir-item=\"\" ngh=\"9\"><a internal-link-handler=\"\" class=\"document-list-card\" href=\"#unreal-doc:whats-new\"><div class=\"thumbnail-container\"><img class=\"unreal-doc-img\" loading=\"lazy\" width=\"120\" height=\"92\" class=\"thumbnail\" src=\"https://dev.epicgames.com/community/api/documentation/image/d21d4eb5-fc0b-4d7a-82b2-a676e8ed94f6?resizing_type=fit&amp;width=640&amp;height=640\" alt=\"What's New\"></div><div class=\"document-list-card-content\"><!----><div class=\"document-list-card-content-info\"><p class=\"title\">What's New</p><p class=\"description\">Information about new features in each release of Unreal Engine</p></div></div></a></li><li block-dir-item=\"\" ngh=\"9\"><a internal-link-handler=\"\" class=\"document-list-card\" href=\"#unreal-doc:understanding-the-basics-of-unreal-engine\"><div class=\"thumbnail-container\"><img class=\"unreal-doc-img\" loading=\"lazy\" width=\"120\" height=\"92\" class=\"thumbnail\" src=\"https://dev.epicgames.com/community/api/documentation/image/31b32dc6-f266-4e2b-9c87-5cc50ca8e533?resizing_type=fit&amp;width=640&amp;height=640\" alt=\"Understanding the Basics\"></div><div class=\"document-list-card-content\"><!----><div class=\"document-list-card-content-info\"><p class=\"title\">Understanding the Basics</p><p class=\"description\">Essential skills and concepts to help you get started in Unreal Engine.</p></div></div></a></li><li block-dir-item=\"\" ngh=\"9\"><a internal-link-handler=\"\" class=\"document-list-card\" href=\"#unreal-doc:working-with-content-in-unreal-engine\"><div class=\"thumbnail-container\"><img class=\"unreal-doc-img\" loading=\"lazy\" width=\"120\" height=\"92\" class=\"thumbnail\" src=\"https://dev.epicgames.com/community/api/documentation/image/8e1a64e2-8173-4cc1-a60f-236db6d2fe18?resizing_type=fit&amp;width=640&amp;height=640\" alt=\"Working with Content\"></div><div class=\"document-list-card-content\"><!----><div class=\"document-list-card-content-info\"><p class=\"title\">Working with Content</p><p class=\"description\">Information on using art created in external applications, importing it into Unreal Engine, and setting it up for use in visualization and interactive applications.</p></div></div></a>